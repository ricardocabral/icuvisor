  "properties": {
    "description": {
      "description": "Optional free-text workout description. Preserved verbatim when workout_doc is omitted; mutually exclusive with workout_doc because intervals.icu accepts one description DSL string on writes.",
      "type": "string"
    },
    "folder_id": {
      "description": "Optional intervals.icu workout-library folder or plan ID to place the new template in. Omit to create a top-level library workout.",
      "type": "string"
    },
    "name": {
      "description": "Required workout-library template name/title. Surrounding whitespace is trimmed.",
      "type": "string"
    },
    "sport": {
      "description": "Required upstream sport/activity type for the workout template, such as Ride, Run, Swim, VirtualRide, or the athlete account's configured activity type.",
      "type": "string"
    },
    "tags": {
      "description": "Optional workout-library tags to preserve on the upstream template, in caller-provided order.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "workout_doc": {
      "description": "Optional structured WorkoutDoc. Mutually exclusive with description; serialized to the upstream workout-description DSL. Syntax reference: icuvisor://workout-syntax.",
      "type": "object"
    }
  },
  "required": [
    "name",
    "sport"
  ],
  "type": "object"
